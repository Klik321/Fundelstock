# ─────────────────────────────────────────────────────────────────────────────
# Fundelstock — Environment Variables
# Copy to .env.local and fill in your keys. Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Finnhub — primary market data + news (free: 60 req/min)
# https://finnhub.io
FINNHUB_API_KEY=

# Alpha Vantage — news sentiment scoring (free: 25 req/day)
# https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=

# NewsAPI — financial headlines (free tier: dev only, 100 req/day)
# https://newsapi.org
NEWSAPI_KEY=

# GNews — alternative news source (free: 100 req/day)
# https://gnews.io
GNEWS_API_KEY=

# Site canonical URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://fundelstock.com
